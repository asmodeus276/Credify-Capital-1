<svg xmlns="http://www.w3.org/2000/svg" width="400" height="250" viewBox="0 0 400 250">
  <defs>
    <linearGradient id="bg" x1="0" x2="1" y1="0" y2="1">
      <stop offset="0%" stop-color="#142450"/>
      <stop offset="100%" stop-color="#1e3a6e"/>
    </linearGradient>
  </defs>
  <rect width="400" height="250" fill="url(#bg)"/>
  <rect x="0" y="244" width="400" height="6" fill="#b61722"/>
  <text x="200" y="110" text-anchor="middle" dominant-baseline="middle"
        font-size="48" fill="rgba(255,255,255,0.15)" font-family="Arial">&#x1F4DD;</text>
  <foreignObject x="20" y="130" width="360" height="60">
    <body xmlns="http://www.w3.org/1999/xhtml">
      <p style="color:#ffffff;font-size:13px;font-family:Arial;text-align:center;margin:0">Personal Loan Emi Calculator</p>
